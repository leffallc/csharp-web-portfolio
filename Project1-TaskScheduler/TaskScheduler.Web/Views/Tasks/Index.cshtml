@model List<Carl.TaskScheduler.Web.Models.TodoTask>

<h1>Task List</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Create Task</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in Model)
        {
            <tr>
                <td>@task.Title</td>
                <td>
                    @(task.IsComplete ? "Complete" : "Pending")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@task.Id">Edit</a>

                    <a asp-action="Delete" asp-route-id="@task.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>