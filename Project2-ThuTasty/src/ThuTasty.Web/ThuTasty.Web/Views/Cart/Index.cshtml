@model List<ThuTasty.Web.Models.CartItem>

@{
    ViewData["Title"] = "Cart";
    var total = Model.Sum(ITempDataDictionary => ITempDataDictionary.Price * ITempDataDictionary.Quantity);
}

<div class="container mt-4">
    <h1 class="fw-bold mb-3">Your Cart</h1>

    @if (!Model.Any())
    {
        <div class="tt-card p-4 text-center">
            <h4>Your cart is empty</h4>
            <p class="text-muted">Add some treats and come back here.</p>
            <a asp-controller="Home" asp-action="Index" class="btn tt-btn-primary">
                Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="tt-card p-3">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Qty</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@item.ImageUrl"
                                         alt="@item.ProductName"
                                         style="height:60px;width:60px;object-fit:cover;border-radius:10px;" />
                                    <strong>@item.ProductName</strong>
                                </div>
                            </td>
                            <td>$@item.Price</td>
                            <td>@item.Quantity</td>
                            <td>$@(item.Price * item.Quantity)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-end mt-3">
            <div class="tt-card p-3" style="min-width:280px;">
                <h4 class="fw-bold">Total: $@total</h4>
                <button class="btn tt-btn-primary w-100 mt-2">
                    Checkout
                </button>
            </div>
        </div>
    }
</div>