@model List<ThuTasty.Web.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="container mt-4">
    <h1 class="fw-bold mb-3">Orders</h1>

    @if (!Model.Any())
    {
        <div class="tt-card p-4 text-center">
            <h4>No orders yet</h4>
            <p class="text-muted">Orders will appear here after customers checkout.</p>
        </div>
    }
    else
    {
        <div class="tt-card p-3">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Order Status</th>
                        <th>Payment Status</th>
                        <th>Provider</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.Id</td>
                            <td>@order.CustomerName</td>
                            <td>@order.Email</td>
                            <td>@order.Items.Sum(i => i.Quantity)</td>
                            <td>@order.TotalAmount.ToString("C")</td>
                            <td>@order.OrderStatus</td>
                            <td>@order.PaymentStatus</td>
                            <td>@order.PaymentProvider</td>
                            <td>@order.CreatedAt.ToString("g")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-dark">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>